# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose to browser

# ─── Cloudflare Turnstile (CAPTCHA) ───────────────────────────────────────────
# SITE KEY  → Cloudflare Dashboard → Turnstile → your widget → Site Key
# SECRET KEY → stored in Supabase Dashboard → Auth → Attack Protection (NOT in this repo)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# ─── Stripe Billing ───────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_...
NEXT_PUBLIC_STRIPE_PRICE_ELITE=price_...

# ─── Resend (Email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://houstontexaspro.com
NEXT_PUBLIC_ROOT_DOMAIN=houstontexaspro.com
